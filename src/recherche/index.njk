---
layout: base
title: Recherche
description: Rechercher dans la réglementation sécurité incendie
permalink: /recherche/index.html
---

<div class="container">
  <h1>🔍 Recherche</h1>

  <form class="search-form-full" id="search-form">
    <input type="text" id="search-input" name="q"
           placeholder="Ex: désenfumage, issue de secours, ERP type M…"
           class="search-input-lg" autocomplete="off">

    <div class="search-filters">
      <label>Catégorie :
        <select id="filter-category" name="category">
          <option value="">Toutes</option>
          <option value="ERP">ERP — Établissements Recevant du Public</option>
          <option value="IGH">IGH — Immeubles de Grande Hauteur</option>
          <option value="HAB">HAB — Habitations</option>
          <option value="BUP">BUP — Bâtiments Usage Professionnel</option>
          <option value="ICPE">ICPE — Installations Classées</option>
          <option value="AUTRES">Autres catégories</option>
        </select>
      </label>
      <button type="submit" class="search-btn-lg">Rechercher</button>
    </div>
  </form>

  <div id="search-results" class="search-results">
    <p class="search-hint">Entrez un terme pour lancer la recherche.</p>
  </div>
</div>

<script>
const CATEGORY_COLORS = {
  ERP: '#C0392B', IGH: '#1A2E4A', HAB: '#27AE60',
  BUP: '#8E44AD', ICPE: '#E67E22', AUTRES: '#2980B9'
};

function renderResults(data) {
  const container = document.getElementById('search-results');
  if (!data.results || data.results.length === 0) {
    container.innerHTML = '<p class="no-results">Aucun résultat trouvé.</p>';
    return;
  }
  const html = `
    <p class="result-count">${data.total} résultat(s) pour "<strong>${data.query || data.category}</strong>"</p>
    <div class="results-list">
      ${data.results.map(r => `
        <div class="result-item">
          <span class="badge" style="background:${CATEGORY_COLORS[r.primaryCategory] || '#999'}">
            ${r.primaryCategory}
          </span>
          <a href="/articles/${r.id}/">${r.title}</a>
          <span class="result-codes">${r.assignedCodes || ''}</span>
        </div>
      `).join('')}
    </div>
    ${data.total > data.results.length ? `<p class="more-results">Affichage de ${data.results.length} sur ${data.total} résultats.</p>` : ''}
  `;
  container.innerHTML = html;
}

function doSearch() {
  const q        = document.getElementById('search-input').value.trim();
  const category = document.getElementById('filter-category').value;
  if (!q && !category) return;

  document.getElementById('search-results').innerHTML = '<p class="loading">Recherche en cours…</p>';

  const params = new URLSearchParams();
  if (q)        params.set('q', q);
  if (category) params.set('category', category);
  params.set('limit', '50');

  fetch('/api/search?' + params.toString())
    .then(r => r.json())
    .then(renderResults)
    .catch(err => {
      document.getElementById('search-results').innerHTML =
        '<p class="error">Erreur de recherche. Réessayez.</p>';
    });
}

document.getElementById('search-form').addEventListener('submit', e => {
  e.preventDefault();
  doSearch();
});

// Pré-remplir depuis l'URL
const urlParams = new URLSearchParams(window.location.search);
const preQ = urlParams.get('q');
const preCat = urlParams.get('category');
if (preQ)   { document.getElementById('search-input').value = preQ; }
if (preCat) { document.getElementById('filter-category').value = preCat; }
if (preQ || preCat) doSearch();
</script>
